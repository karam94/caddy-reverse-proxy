{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges
	}
}

:{$PORT} {

	log {
		format json
	}

	# =========================
	# API (backend)
	# =========================
	handle {$BACKEND_PATH:/api}/* {
		reverse_proxy {$BACKEND_DOMAIN}:{$BACKEND_PORT}
	}

	# =========================
	# FRONTEND (catch-all)
	# =========================
	handle {
		reverse_proxy {$FRONTEND_DOMAIN}:{$FRONTEND_PORT}
	}
}
